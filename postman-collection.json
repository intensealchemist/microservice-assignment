{
  "info": {
    "name": "Social Media API",
    "description": "Backend API with bot guardrails",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Users",
      "item": [
        {
          "name": "Create User",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"username\": \"alice\", \"isPremium\": true}"
            },
            "url": {
              "raw": "http://localhost:8080/api/users",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8080",
              "path": ["api", "users"]
            }
          }
        }
      ]
    },
    {
      "name": "Posts",
      "item": [
        {
          "name": "Create Post",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"authorId\": 1, \"authorType\": \"USER\", \"content\": \"Hello world\"}"
            },
            "url": {
              "raw": "http://localhost:8080/api/posts",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8080",
              "path": ["api", "posts"]
            }
          }
        },
        {
          "name": "Get All Posts",
          "request": {
            "method": "GET",
            "url": {
              "raw": "http://localhost:8080/api/posts",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8080",
              "path": ["api", "posts"]
            }
          }
        },
        {
          "name": "Like Post",
          "request": {
            "method": "POST",
            "url": {
              "raw": "http://localhost:8080/api/posts/1/like?userId=1",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8080",
              "path": ["api", "posts", "1", "like"],
              "query": [
                {
                  "key": "userId",
                  "value": "1"
                }
              ]
            }
          }
        },
        {
          "name": "Add Comment",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"authorId\": 1, \"authorType\": \"BOT\", \"content\": \"Nice post!\", \"parentCommentId\": null}"
            },
            "url": {
              "raw": "http://localhost:8080/api/posts/1/comments",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8080",
              "path": ["api", "posts", "1", "comments"]
            }
          }
        }
      ]
    }
  ]
}
